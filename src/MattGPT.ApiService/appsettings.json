{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LLM": {
    "Provider": "Ollama",
    "ModelId": "llama3.2",
    "EmbeddingModelId": "nomic-embed-text",
    "Endpoint": "http://localhost:11434"
  },
  "RAG": {
    "Mode": "WithPrompt",
    "TopK": 5,
    "MinScore": 0.5,
    "AutoTopK": 2,
    "AutoMinScore": 0.65,
    "ToolMaxResults": 5,
    "DiagnosticMode": false
  },
  "Chat": {
    "MaxConversationTokens": 2048,
    "RecentMessageCount": 6
  },
  "VectorStore": {
    "Provider": "Qdrant"
  },
  "Auth": {
    "Enabled": false
  }
}
