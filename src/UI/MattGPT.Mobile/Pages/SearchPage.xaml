<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MattGPT.UI.Pages.SearchPage"
             Title="Search">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InverseBoolConverter" />
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringToBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *" Padding="16">

        <!-- Search input -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*, Auto"
              ColumnSpacing="8"
              Margin="0,0,0,8">
            <Entry Grid.Column="0"
                   Text="{Binding Query}"
                   Placeholder="Search your conversation history…"
                   ReturnCommand="{Binding SearchCommand}"
                   IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBoolConverter}}" />
            <Button Grid.Column="1"
                    Text="Search"
                    Command="{Binding SearchCommand}" />
        </Grid>

        <!-- Error message -->
        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
               TextColor="Red"
               FontSize="12"
               Margin="0,0,0,8" />

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsSearching}"
                           IsVisible="{Binding IsSearching}"
                           HorizontalOptions="Center"
                           VerticalOptions="Start"
                           Margin="0,16,0,0" />

        <!-- Results list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Results}"
                        IsVisible="{Binding IsSearching, Converter={StaticResource InverseBoolConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 8"
                            Padding="12"
                            Margin="0,0,0,8"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="14" />
                            <Label Text="{Binding Summary}"
                                   FontSize="12"
                                   TextColor="Gray"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Score, StringFormat='Relevance: {0:P0}'}"
                                   FontSize="11"
                                   TextColor="Gray"
                                   HorizontalOptions="End" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No results. Try a different search query."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="Gray"
                       Margin="20" />
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>

</ContentPage>
