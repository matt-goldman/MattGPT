<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MattGPT.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MattGPT.Mobile.Pages.ChatPage"
             x:DataType="vm:ChatViewModel"
             Title="{Binding SessionTitle}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InverseBoolConverter" />
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringToBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto, Auto">

        <!-- Message list -->
        <CollectionView Grid.Row="0" ItemsSource="{Binding Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ChatMessage">
                    <Grid Padding="12,6">
                        <Border StrokeShape="RoundRectangle 12"
                                Padding="12,8"
                                HorizontalOptions="Start"
                                BackgroundColor="{StaticResource Gray100}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsUser}" Value="True">
                                    <Setter Property="HorizontalOptions" Value="End" />
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout>
                                <Label Text="{Binding Content}" FontSize="14">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="Gray"
                                       HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No messages yet. Type a message below to get started."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="Gray"
                       Margin="20" />
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Tool status indicator -->
        <Label Grid.Row="1"
               Text="{Binding ToolStatusMessage}"
               IsVisible="{Binding ToolStatusMessage, Converter={StaticResource StringToBoolConverter}}"
               FontSize="12"
               TextColor="Gray"
               HorizontalOptions="Center"
               Margin="8,4" />

        <!-- Input area -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*, Auto"
              Padding="8"
              ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Text="{Binding UserInput}"
                   Placeholder="Type a message…"
                   ReturnCommand="{Binding SendMessageCommand}"
                   IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBoolConverter}}" />
            <Button Grid.Column="1"
                    Text="Send"
                    Command="{Binding SendMessageCommand}" />
        </Grid>

    </Grid>

</ContentPage>
