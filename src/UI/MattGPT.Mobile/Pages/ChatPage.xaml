<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MattGPT.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:MattGPT.Mobile.Controls"
             xmlns:idk="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
             x:Class="MattGPT.Mobile.Pages.ChatPage"
             x:DataType="vm:ChatViewModel"
             Title="{Binding SessionTitle}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InverseBoolConverter" />
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringToBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto, Auto">

        <!-- Message list -->
        <CollectionView Grid.Row="0" ItemsSource="{Binding Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ChatMessage">
                    <Grid Padding="20,6">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                Padding="12,8"
                                HorizontalOptions="Start"
                                BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsUser}" Value="True">
                                    <Setter Property="HorizontalOptions" Value="End" />
                                    <Setter Property="BackgroundColor" Value="{StaticResource Gray100}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout>
                                <ActivityIndicator Color="Gray"
                                                   WidthRequest="20"
                                                   IsRunning="{Binding IsThinking}"
                                                   IsVisible="{Binding IsThinking}" />
                                <idk:MarkdownView MarkdownText="{Binding Content}" TextFontSize="14" />
                                <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="Gray"
                                       HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No messages yet. Type a message below to get started."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="Gray"
                       Margin="20" />
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Tool status indicator -->
        <Label Grid.Row="1"
               Text="{Binding ToolStatusMessage}"
               IsVisible="{Binding ToolStatusMessage, Converter={StaticResource StringToBoolConverter}}"
               FontSize="12"
               TextColor="Gray"
               HorizontalOptions="Center"
               Margin="8,4" />

        <controls:AIEditor Grid.Row="2"
                           Margin="20,5,20,2"
                           Prompt="{Binding UserInput, Mode=TwoWay}"
                           SendCommand="{Binding SendMessageCommand}"
                           IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBoolConverter}}" />

    </Grid>

</ContentPage>
