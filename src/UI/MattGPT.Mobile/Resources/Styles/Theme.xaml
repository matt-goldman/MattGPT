<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:fs="clr-namespace:FlagstoneUI.Core.Controls;assembly=FlagstoneUI.Core"
                    x:Class="MattGPT.Mobile.Resources.Styles.Theme">

    <!-- default entry style -->
    <Style TargetType="fs:FsEntry">
        <Setter Property="BorderBrush" Value="{AppThemeBinding Light=Black, Dark=White}" />
        <Setter Property="PlaceholderColor" Value="Gray"/>
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
</ResourceDictionary>