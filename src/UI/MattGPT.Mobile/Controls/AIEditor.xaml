<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fs="clr-namespace:FlagstoneUI.Core.Controls;assembly=FlagstoneUI.Core"
             xmlns:icons="clr-namespace:Plugin.Maui.Lucide;assembly=Plugin.Maui.Lucide"
             x:Class="MattGPT.Mobile.Controls.AIEditor">
    <Border StrokeShape="RoundRectangle 8"
            Stroke="Black"
            StrokeThickness="1">
        <FlexLayout Direction="Column"
                    Padding="10,25">
            <fs:FsEditor x:Name="InputEditor"
                         Placeholder="How can I help you today?"
                         AutoSize="TextChanges"
                         TextChanged="InputEditor_TextChanged" 
                         Margin="0"
                         Padding="0"/>
            <FlexLayout Direction="Row"
                        JustifyContent="End"
                        AlignItems="Center">
                <!-- TODO: add two collections, start actions and end actions -->
                <fs:FsButton x:Name="EndAction"
                             Text="{x:Static icons:Icons.AudioLines}"
                             Clicked="EndAction_Clicked"
                             WidthRequest="20"
                             HeightRequest="20"
                             CornerRadius="10"
                             FontFamily="lucide" />
            </FlexLayout>
        </FlexLayout>
    </Border>
</ContentView>
