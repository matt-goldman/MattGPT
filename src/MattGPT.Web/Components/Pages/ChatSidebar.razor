@rendermode InteractiveServer
@inject IHttpClientFactory HttpClients
@using System.Text.Json

<div class="flex flex-col h-full bg-default-50 border-r border-default-200">
    @* New chat button *@
    <div class="p-3 border-b border-default-200">
        <LumexButton Color="@ThemeColor.Primary"
                     Variant="@Variant.Flat"
                     Class="w-full justify-start gap-2"
                     OnClick="@(() => OnNewChat.InvokeAsync())">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Chat
        </LumexButton>
    </div>

    @* Scrollable session list *@
    <div class="flex-1 overflow-y-auto">
        @if (_isLoading)
        {
            <div class="flex justify-center p-4">
                <LumexSpinner Color="@ThemeColor.Primary" Size="@Size.Small" />
            </div>
        }
        else
        {
            @* Chat sessions *@
            @if (_chatSessions.Count > 0)
            {
                <div class="px-3 pt-3 pb-1">
                    <span class="text-xs font-semibold text-default-400 uppercase tracking-wider">Your Chats</span>
                </div>
                @foreach (var session in _chatSessions)
                {
                    var isActive = ActiveSessionId == session.SessionId;
                    <button class="@SidebarItemClass(isActive, false)"
                            @onclick="@(() => OnSessionSelected.InvokeAsync(session.SessionId))">
                        <div class="flex items-center gap-2 min-w-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                            </svg>
                            <div class="min-w-0 flex-1 text-left">
                                <div class="text-sm truncate">@(session.Title ?? "Untitled")</div>
                                <div class="text-xs text-default-400">@FormatRelativeDate(session.UpdatedAt)</div>
                            </div>
                        </div>
                    </button>
                }
            }

            @* Imported conversations *@
            @if (_importedConversations.Count > 0)
            {
                <div class="px-3 pt-4 pb-1 flex items-center justify-between">
                    <span class="text-xs font-semibold text-default-400 uppercase tracking-wider">Imported History</span>
                    <span class="text-xs text-default-400">@_importedTotal total</span>
                </div>

                @* Search box for imported conversations *@
                <div class="px-3 pb-2">
                    <input type="text"
                           @bind="_searchQuery"
                           @bind:event="oninput"
                           @bind:after="FilterImported"
                           placeholder="Filter imported..."
                           aria-label="Filter imported conversations"
                           class="w-full text-xs rounded-md border border-default-200 bg-default-100 px-2 py-1.5 focus:outline-none focus:border-primary" />
                </div>

                @foreach (var conv in _filteredImported)
                {
                    var isActive = ActiveConversationId == conv.ConversationId;
                    <button class="@SidebarItemClass(isActive, true)"
                            @onclick="@(() => OnConversationSelected.InvokeAsync(conv.ConversationId))">
                        <div class="flex items-center gap-2 min-w-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-default-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                            <div class="min-w-0 flex-1 text-left">
                                <div class="text-sm truncate">@(conv.Title ?? "Untitled")</div>
                                <div class="text-xs text-default-400">@FormatImportedDate(conv.CreateTime)</div>
                            </div>
                        </div>
                    </button>
                }

                @if (_importedTotal > _importedConversations.Count)
                {
                    <div class="px-3 py-2 text-center">
                        <button class="text-xs text-primary hover:underline" @onclick="LoadMoreImported">
                            Load more...
                        </button>
                    </div>
                }
            }

            @if (_chatSessions.Count == 0 && _importedConversations.Count == 0)
            {
                <div class="p-4 text-sm text-default-400 text-center">
                    No conversation history yet.
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public Guid? ActiveSessionId { get; set; }
    [Parameter] public string? ActiveConversationId { get; set; }
    [Parameter] public EventCallback OnNewChat { get; set; }
    [Parameter] public EventCallback<Guid> OnSessionSelected { get; set; }
    [Parameter] public EventCallback<string> OnConversationSelected { get; set; }

    private List<ChatSessionItem> _chatSessions = [];
    private List<ImportedConversationItem> _importedConversations = [];
    private List<ImportedConversationItem> _filteredImported = [];
    private long _importedTotal;
    private int _importedPage = 1;
    private bool _isLoading = true;
    private string _searchQuery = string.Empty;

    private static readonly JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    /// <summary>Refresh the sidebar data (called from parent after chat activity).</summary>
    public async Task RefreshAsync()
    {
        await LoadDataAsync();
        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var client = HttpClients.CreateClient("apiservice");

            // Load chat sessions and imported conversations in parallel.
            var sessionsTask = client.GetFromJsonAsync<List<ChatSessionItem>>("/chat/sessions?limit=50", _jsonOptions);
            var conversationsTask = client.GetFromJsonAsync<ConversationsResponse>("/conversations?page=1&pageSize=50", _jsonOptions);

            await Task.WhenAll(sessionsTask, conversationsTask);

            _chatSessions = sessionsTask.Result ?? [];
            var convResult = conversationsTask.Result;
            if (convResult is not null)
            {
                _importedConversations = convResult.Items?.ToList() ?? [];
                _importedTotal = convResult.Total;
                _importedPage = 1;
            }
            FilterImported();
        }
        catch
        {
            // Sidebar loading failure is non-critical; show empty state.
            _chatSessions = [];
            _importedConversations = [];
            _filteredImported = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMoreImported()
    {
        try
        {
            _importedPage++;
            var client = HttpClients.CreateClient("apiservice");
            var result = await client.GetFromJsonAsync<ConversationsResponse>(
                $"/conversations?page={_importedPage}&pageSize=50", _jsonOptions);
            if (result?.Items is not null)
            {
                _importedConversations.AddRange(result.Items);
                FilterImported();
            }
        }
        catch
        {
            // Non-critical; ignore.
        }
    }

    private void FilterImported()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _filteredImported = _importedConversations;
        }
        else
        {
            _filteredImported = _importedConversations
                .Where(c => c.Title?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) == true)
                .ToList();
        }
    }

    private static string SidebarItemClass(bool isActive, bool isImported) =>
        $"w-full px-3 py-2 hover:bg-default-100 transition-colors cursor-pointer text-left {(isActive ? "bg-default-200" : "")}";

    private static string FormatRelativeDate(DateTimeOffset date)
    {
        var diff = DateTimeOffset.UtcNow - date;
        return diff.TotalMinutes < 1 ? "just now" :
               diff.TotalMinutes < 60 ? $"{(int)diff.TotalMinutes}m ago" :
               diff.TotalHours < 24 ? $"{(int)diff.TotalHours}h ago" :
               diff.TotalDays < 7 ? $"{(int)diff.TotalDays}d ago" :
               date.ToString("MMM d");
    }

    private static string FormatImportedDate(double? unixTimestamp)
    {
        if (unixTimestamp is null) return "";
        var date = DateTimeOffset.FromUnixTimeSeconds((long)unixTimestamp.Value);
        return date.ToString("MMM d, yyyy");
    }

    // DTOs for deserialisation
    private record ChatSessionItem(Guid SessionId, string? Title, DateTimeOffset CreatedAt, DateTimeOffset UpdatedAt, string Status, int MessageCount);
    private record ImportedConversationItem(string ConversationId, string? Title, double? CreateTime, double? UpdateTime, int MessageCount);
    private record ConversationsResponse(int Page, int PageSize, long Total, List<ImportedConversationItem> Items);
}
