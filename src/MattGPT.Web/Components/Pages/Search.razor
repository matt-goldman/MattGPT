@page "/search"
@rendermode InteractiveServer
@implements IDisposable
@inject ISearchService SearchService
@inject NavigationManager Navigation

<PageTitle>Search Conversations</PageTitle>

<div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">Search Conversations</h1>

    <div class="flex gap-2 mb-6">
        <input type="text"
               @bind="_query"
               @bind:event="oninput"
               @bind:after="OnQueryChanged"
               placeholder="Search your conversation history..."
               class="flex-1 rounded-lg border border-default-200 bg-default-50 px-3 py-2 text-sm focus:outline-none focus:border-primary"
               @onkeydown="HandleKeyDown" />
        <LumexButton Color="@ThemeColor.Primary"
                     IsDisabled="@(string.IsNullOrWhiteSpace(_query) || _isSearching)"
                     OnClick="RunSearch">
            Search
        </LumexButton>
    </div>

    @if (_isSearching)
    {
        <div class="flex justify-center py-8">
            <LumexSpinner Color="@ThemeColor.Primary" />
        </div>
    }
    else if (_hasSearched && _results.Count == 0)
    {
        <div class="text-center text-default-400 py-8">
            <p>No conversations found for "@_lastQuery".</p>
            <p class="text-xs mt-1">Try a different query or make sure your conversations have been imported and embedded.</p>
        </div>
    }
    else if (_results.Count > 0)
    {
        <p class="text-xs text-default-400 mb-3">@_results.Count result(s) for "@_lastQuery"</p>
        <div class="space-y-3">
            @foreach (var result in _results)
            {
                <button class="w-full text-left rounded-xl border border-default-200 hover:border-primary bg-white hover:bg-primary-50 transition-colors p-4"
                        @onclick="() => NavigateToConversation(result.ConversationId)">
                    <div class="flex items-start justify-between gap-2">
                        <div class="min-w-0 flex-1">
                            <div class="font-medium text-sm truncate">@(result.Title ?? "Untitled")</div>
                            @if (!string.IsNullOrWhiteSpace(result.Summary))
                            {
                                <p class="text-xs text-default-500 mt-1 line-clamp-2">@result.Summary</p>
                            }
                        </div>
                        <span class="text-xs text-default-400 shrink-0 mt-0.5">
                            relevance: @result.Score.ToString("P0")
                        </span>
                    </div>
                </button>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <LumexAlert Color="@ThemeColor.Danger" Title="Error" Class="mt-4">
            @_errorMessage
        </LumexAlert>
    }
</div>

@code {
    private string _query = string.Empty;
    private string _lastQuery = string.Empty;
    private bool _isSearching;
    private bool _hasSearched;
    private string _errorMessage = string.Empty;
    private readonly List<SearchResult> _results = [];
    private System.Threading.Timer? _debounceTimer;

    private void OnQueryChanged()
    {
        // Debounce search-as-you-type
        _debounceTimer?.Dispose();
        if (string.IsNullOrWhiteSpace(_query)) return;
        _debounceTimer = new System.Threading.Timer(_ => InvokeAsync(RunSearch), null, 500, System.Threading.Timeout.Infinite);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_query) && !_isSearching)
        {
            _debounceTimer?.Dispose();
            await RunSearch();
        }
    }

    private async Task RunSearch()
    {
        var q = _query.Trim();
        if (string.IsNullOrEmpty(q) || _isSearching) return;

        _isSearching = true;
        _errorMessage = string.Empty;
        _results.Clear();
        StateHasChanged();

        try
        {
            var searchResults = await SearchService.SearchAsync(q, limit: 20);
            _results.AddRange(searchResults);
            _lastQuery = q;
            _hasSearched = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private void NavigateToConversation(string conversationId)
    {
        Navigation.NavigateTo($"/chat/conversation/{conversationId}");
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
