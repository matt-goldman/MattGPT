@page "/"
@page "/upload"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClients

<PageTitle>Upload Conversations</PageTitle>

<div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-2">Upload Conversations</h1>
    <p class="text-default-500 mb-6">
        Upload your ChatGPT <code class="font-mono text-sm bg-default-100 px-1 rounded">conversations.json</code> export file(s) to import your conversation history.
        You can select multiple files at once.
    </p>

    <LumexCard Class="p-6">
        <div class="space-y-4">
            @if (_pageStatus == PageStatus.Idle || _pageStatus == PageStatus.Error)
            {
                <div class="border-2 border-dashed border-default-200 rounded-lg p-8 text-center">
                    <p class="text-default-500 mb-4">Select your <code class="font-mono text-sm">conversations.json</code> file(s) (up to 200 MB each)</p>
                    <InputFile OnChange="OnFilesSelected"
                               accept=".json"
                               multiple
                               class="block w-full text-sm text-default-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary file:text-white hover:file:opacity-80 cursor-pointer" />
                    @if (_selectedFiles.Count > 0)
                    {
                        <div class="mt-3 text-sm text-default-600 text-left">
                            <p class="font-medium mb-1">@_selectedFiles.Count file(s) selected:</p>
                            <ul class="list-disc list-inside space-y-0.5">
                                @foreach (var file in _selectedFiles)
                                {
                                    <li>@file.Name <span class="text-default-400">(@FormatBytes(file.Size))</span></li>
                                }
                            </ul>
                        </div>
                    }
                </div>

                @if (_pageStatus == PageStatus.Error)
                {
                    <LumexAlert Color="@ThemeColor.Danger" Title="Selection error">
                        @_selectionError
                    </LumexAlert>
                }

                <div class="flex justify-end">
                    <LumexButton Color="@ThemeColor.Primary"
                                 IsDisabled="@(_selectedFiles.Count == 0)"
                                 OnClick="StartUpload">
                        Upload & Process
                    </LumexButton>
                </div>
            }
            else if (_pageStatus == PageStatus.Working)
            {
                @* Per-file progress list *@
                <div class="space-y-3">
                    @foreach (var tracker in _fileTrackers)
                    {
                        <div class="border border-default-200 rounded-lg p-4">
                            <div class="flex items-center justify-between mb-2">
                                <span class="font-medium text-sm truncate max-w-[70%]" title="@tracker.FileName">@tracker.FileName</span>
                                <span class="text-xs px-2 py-0.5 rounded-full @GetStatusBadgeClass(tracker.Status)">@GetStatusLabel(tracker.Status)</span>
                            </div>

                            @switch (tracker.Status)
                            {
                                case FileStatus.Pending:
                                    <p class="text-xs text-default-400">Waiting in queue…</p>
                                    break;

                                case FileStatus.Uploading:
                                    <div class="flex items-center gap-2">
                                        <LumexSpinner Size="@Size.Small" Color="@ThemeColor.Primary" />
                                        <span class="text-xs text-default-500">Uploading…</span>
                                    </div>
                                    break;

                                case FileStatus.Processing:
                                    <div class="flex items-center gap-2">
                                        <LumexSpinner Size="@Size.Small" Color="@ThemeColor.Primary" />
                                        <span class="text-xs text-default-500">
                                            Importing… @tracker.ProcessedConversations conversation(s)
                                            @if (tracker.ErrorCount > 0)
                                            {
                                                <span class="text-danger">(@tracker.ErrorCount errors)</span>
                                            }
                                        </span>
                                    </div>
                                    break;

                                case FileStatus.Embedding:
                                    <div class="space-y-1">
                                        <div class="flex items-center gap-2">
                                            <LumexSpinner Size="@Size.Small" Color="@ThemeColor.Secondary" />
                                            <span class="text-xs text-default-500">
                                                Embedding… @tracker.EmbeddedConversations / @tracker.ProcessedConversations
                                            </span>
                                        </div>
                                        @{
                                            var pct = tracker.ProcessedConversations > 0
                                                ? (int)(100.0 * tracker.EmbeddedConversations / tracker.ProcessedConversations)
                                                : 0;
                                        }
                                        <div class="w-full bg-default-100 rounded-full h-1.5">
                                            <div class="bg-secondary h-1.5 rounded-full transition-all duration-300" style="width: @(pct)%"></div>
                                        </div>
                                    </div>
                                    break;

                                case FileStatus.Complete:
                                    <p class="text-xs text-success">
                                        @tracker.ProcessedConversations conversation(s) imported, @tracker.EmbeddedConversations embedded.
                                        @if (tracker.ErrorCount > 0)
                                        {
                                            <span class="text-warning"> @tracker.ErrorCount error(s).</span>
                                        }
                                    </p>
                                    break;

                                case FileStatus.UploadFailed:
                                case FileStatus.ProcessingFailed:
                                    <p class="text-xs text-danger">@tracker.ErrorMessage</p>
                                    break;

                                case FileStatus.EmbeddingFailed:
                                    <p class="text-xs text-default-500">
                                        @tracker.ProcessedConversations conversation(s) imported.
                                    </p>
                                    <p class="text-xs text-warning">Embedding failed: @tracker.EmbeddingErrorMessage</p>
                                    break;
                            }
                        </div>
                    }
                </div>
            }
            else if (_pageStatus == PageStatus.Complete)
            {
                @* Summary *@
                <div class="flex flex-col items-center py-8 space-y-4">
                    <div class="w-16 h-16 rounded-full bg-success-100 flex items-center justify-center text-3xl">✓</div>

                    @{
                        var totalProcessed = _fileTrackers.Sum(t => t.ProcessedConversations);
                        var totalEmbedded = _fileTrackers.Sum(t => t.EmbeddedConversations);
                        var totalErrors = _fileTrackers.Sum(t => t.ErrorCount);
                        var totalEmbeddingErrors = _fileTrackers.Sum(t => t.EmbeddingErrors);
                        var failedFiles = _fileTrackers.Count(t => t.Status is FileStatus.UploadFailed or FileStatus.ProcessingFailed);
                        var embeddingFailedFiles = _fileTrackers.Count(t => t.Status == FileStatus.EmbeddingFailed);
                    }

                    <LumexAlert Color="@ThemeColor.Success" Title="Import complete">
                        Processed @_fileTrackers.Count file(s): @totalProcessed conversation(s) imported, @totalEmbedded embedded.
                    </LumexAlert>

                    @if (failedFiles > 0)
                    {
                        <LumexAlert Color="@ThemeColor.Danger" Title="File failures">
                            @failedFiles file(s) failed to process. See details above.
                        </LumexAlert>
                    }

                    @if (totalErrors > 0)
                    {
                        <LumexAlert Color="@ThemeColor.Warning" Title="Some conversations had errors">
                            @totalErrors conversation(s) could not be parsed and were skipped.
                        </LumexAlert>
                    }

                    @if (embeddingFailedFiles > 0 || totalEmbeddingErrors > 0)
                    {
                        <LumexAlert Color="@ThemeColor.Warning" Title="Embedding issues">
                            @if (embeddingFailedFiles > 0)
                            {
                                <span>@embeddingFailedFiles file(s) had embedding failures. </span>
                            }
                            @if (totalEmbeddingErrors > 0)
                            {
                                <span>@totalEmbeddingErrors conversation(s) failed to embed. </span>
                            }
                            <span>You can retry via POST /conversations/embed.</span>
                        </LumexAlert>
                    }

                    @* Per-file breakdown *@
                    @if (_fileTrackers.Count > 1)
                    {
                        <details class="w-full">
                            <summary class="text-sm text-default-500 cursor-pointer hover:text-default-700">Per-file details</summary>
                            <div class="mt-2 space-y-2">
                                @foreach (var tracker in _fileTrackers)
                                {
                                    <div class="flex items-center justify-between text-xs border-b border-default-100 pb-1">
                                        <span class="truncate max-w-[60%]" title="@tracker.FileName">@tracker.FileName</span>
                                        <span>
                                            @if (tracker.Status is FileStatus.UploadFailed or FileStatus.ProcessingFailed)
                                            {
                                                <span class="text-danger">Failed</span>
                                            }
                                            else
                                            {
                                                <span class="text-success">@tracker.ProcessedConversations imported</span>
                                                @if (tracker.ErrorCount > 0)
                                                {
                                                    <span class="text-warning">, @tracker.ErrorCount errors</span>
                                                }
                                            }
                                        </span>
                                    </div>
                                }
                            </div>
                        </details>
                    }

                    <LumexButton Color="@ThemeColor.Default" Variant="@Variant.Outlined" OnClick="Reset">
                        Upload more files
                    </LumexButton>
                </div>
            }
        </div>
    </LumexCard>
</div>

@code {
    // — Page-level status —
    private enum PageStatus { Idle, Error, Working, Complete }

    // — Per-file status —
    private enum FileStatus { Pending, Uploading, Processing, Embedding, Complete, UploadFailed, ProcessingFailed, EmbeddingFailed }

    /// <summary>Tracks the state of a single file upload + processing job.</summary>
    private class FileTracker
    {
        public string FileName { get; init; } = default!;
        public long FileSize { get; init; }
        public IBrowserFile BrowserFile { get; init; } = default!;
        public FileStatus Status { get; set; } = FileStatus.Pending;
        public string? JobId { get; set; }
        public int ProcessedConversations { get; set; }
        public int ErrorCount { get; set; }
        public int EmbeddedConversations { get; set; }
        public int EmbeddingErrors { get; set; }
        public string? ErrorMessage { get; set; }
        public string? EmbeddingErrorMessage { get; set; }

        /// <summary>True when this file has reached a terminal state.</summary>
        public bool IsTerminal => Status is FileStatus.Complete
            or FileStatus.UploadFailed
            or FileStatus.ProcessingFailed
            or FileStatus.EmbeddingFailed;
    }

    private PageStatus _pageStatus = PageStatus.Idle;
    private string _selectionError = string.Empty;
    private readonly List<IBrowserFile> _selectedFiles = new();
    private readonly List<FileTracker> _fileTrackers = new();

    private const long MaxFileSize = 209_715_200; // 200 MB
    private const int MaxFileCount = 50;

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _pageStatus = PageStatus.Idle;
        _selectionError = string.Empty;
        _selectedFiles.Clear();

        var files = e.GetMultipleFiles(MaxFileCount);
        var errors = new List<string>();

        foreach (var file in files)
        {
            if (!file.Name.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
            {
                errors.Add($"{file.Name}: not a .json file.");
                continue;
            }

            if (file.Size > MaxFileSize)
            {
                errors.Add($"{file.Name}: exceeds the 200 MB limit ({FormatBytes(file.Size)}).");
                continue;
            }

            _selectedFiles.Add(file);
        }

        if (errors.Count > 0)
        {
            _pageStatus = PageStatus.Error;
            _selectionError = string.Join(" ", errors);
        }
    }

    private async Task StartUpload()
    {
        if (_selectedFiles.Count == 0) return;

        // Build trackers for each file.
        _fileTrackers.Clear();
        foreach (var file in _selectedFiles)
        {
            _fileTrackers.Add(new FileTracker
            {
                FileName = file.Name,
                FileSize = file.Size,
                BrowserFile = file,
            });
        }

        _pageStatus = PageStatus.Working;
        StateHasChanged();

        var client = HttpClients.CreateClient("apiservice");

        // Upload files sequentially — each is queued in the API and processed in order.
        foreach (var tracker in _fileTrackers)
        {
            await UploadSingleFileAsync(tracker, client);
            StateHasChanged();
        }

        // All files uploaded (or failed to upload). Now poll until every job reaches a terminal state.
        await PollAllJobsAsync(client);

        _pageStatus = PageStatus.Complete;
        StateHasChanged();
    }

    private async Task UploadSingleFileAsync(FileTracker tracker, HttpClient client)
    {
        tracker.Status = FileStatus.Uploading;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            await using var stream = tracker.BrowserFile.OpenReadStream(MaxFileSize);
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new("application/json");
            content.Add(streamContent, "file", tracker.FileName);

            var response = await client.PostAsync("/conversations/upload", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResponse>();
                tracker.JobId = result?.JobId;
                tracker.Status = FileStatus.Processing;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                tracker.Status = FileStatus.UploadFailed;
                tracker.ErrorMessage = $"Upload failed ({(int)response.StatusCode}): {error}";
            }
        }
        catch (Exception ex)
        {
            tracker.Status = FileStatus.UploadFailed;
            tracker.ErrorMessage = $"Upload error: {ex.Message}";
        }
    }

    /// <summary>
    /// Polls all non-terminal jobs until every one has finished (completed, failed, or embedding done/failed).
    /// </summary>
    private async Task PollAllJobsAsync(HttpClient client)
    {
        while (_fileTrackers.Any(t => !t.IsTerminal && t.JobId is not null))
        {
            await Task.Delay(2000);

            foreach (var tracker in _fileTrackers.Where(t => !t.IsTerminal && t.JobId is not null))
            {
                try
                {
                    var resp = await client.GetAsync($"/conversations/status/{tracker.JobId}");
                    if (!resp.IsSuccessStatusCode) continue;

                    var job = await resp.Content.ReadFromJsonAsync<JobStatusResponse>();
                    if (job is null) continue;

                    tracker.ProcessedConversations = job.ProcessedConversations;
                    tracker.ErrorCount = job.ErrorCount;
                    tracker.EmbeddedConversations = job.EmbeddedConversations;
                    tracker.EmbeddingErrors = job.EmbeddingErrors;

                    if (job.Status == "Failed")
                    {
                        tracker.Status = FileStatus.ProcessingFailed;
                        tracker.ErrorMessage = job.ErrorMessage ?? "Processing failed.";
                        continue;
                    }

                    if (job.Status == "Processing" || job.Status == "Queued")
                    {
                        tracker.Status = FileStatus.Processing;
                        continue;
                    }

                    // Status == "Complete" — check embedding phase
                    switch (job.EmbeddingStatus)
                    {
                        case "NotStarted":
                        case "InProgress":
                            tracker.Status = FileStatus.Embedding;
                            break;
                        case "Complete":
                            tracker.Status = FileStatus.Complete;
                            break;
                        case "Failed":
                            tracker.Status = FileStatus.EmbeddingFailed;
                            tracker.EmbeddingErrorMessage = job.EmbeddingErrorMessage ?? "unknown error";
                            break;
                    }
                }
                catch
                {
                    // Polling errors for individual jobs are non-fatal; retry next cycle.
                }
            }

            StateHasChanged();
        }
    }

    private void Reset()
    {
        _selectedFiles.Clear();
        _fileTrackers.Clear();
        _pageStatus = PageStatus.Idle;
        _selectionError = string.Empty;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1_048_576.0:F1} MB";
    }

    private static string GetStatusBadgeClass(FileStatus status) => status switch
    {
        FileStatus.Pending => "bg-default-100 text-default-500",
        FileStatus.Uploading => "bg-primary-100 text-primary",
        FileStatus.Processing => "bg-primary-100 text-primary",
        FileStatus.Embedding => "bg-secondary-100 text-secondary",
        FileStatus.Complete => "bg-success-100 text-success",
        FileStatus.UploadFailed or FileStatus.ProcessingFailed => "bg-danger-100 text-danger",
        FileStatus.EmbeddingFailed => "bg-warning-100 text-warning",
        _ => "bg-default-100 text-default-500",
    };

    private static string GetStatusLabel(FileStatus status) => status switch
    {
        FileStatus.Pending => "Queued",
        FileStatus.Uploading => "Uploading",
        FileStatus.Processing => "Processing",
        FileStatus.Embedding => "Embedding",
        FileStatus.Complete => "Complete",
        FileStatus.UploadFailed => "Upload Failed",
        FileStatus.ProcessingFailed => "Failed",
        FileStatus.EmbeddingFailed => "Partial",
        _ => "Unknown",
    };

    private record UploadResponse(string JobId);

    private record JobStatusResponse(
        string JobId,
        string? FileName,
        string Status,
        int ProcessedConversations,
        int ErrorCount,
        string? ErrorMessage,
        string EmbeddingStatus,
        int EmbeddedConversations,
        int EmbeddingErrors,
        int EmbeddingSkipped,
        string? EmbeddingErrorMessage);
}
