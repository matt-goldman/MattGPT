@page "/chat"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IHttpClientFactory HttpClients
@inject IJSRuntime JS
@using System.IO
@using System.Text.Json

<PageTitle>Chat</PageTitle>

<div class="max-w-4xl mx-auto flex flex-col" style="height: calc(100vh - 120px);">
    <div class="mb-4">
        <h1 class="text-2xl font-bold">Chat</h1>
        <p class="text-default-500 text-sm">Ask anything — responses are augmented with your imported conversation history.</p>
    </div>

    @* Message history *@
    <div class="flex-1 overflow-y-auto space-y-4 mb-4 pr-1" id="chat-messages">
        @if (_messages.Count == 0)
        {
            <div class="flex items-center justify-center h-full text-default-400 text-sm">
                <p>No messages yet. Type a message below to get started.</p>
            </div>
        }

        @foreach (var msg in _messages)
        {
            @if (msg.Role == "user")
            {
                <div class="flex justify-end">
                    <div class="max-w-lg bg-primary text-white rounded-2xl rounded-tr-sm px-4 py-2 text-sm">
                        @msg.Content
                    </div>
                </div>
            }
            else
            {
                <div class="space-y-2">
                    <div class="flex justify-start">
                        <div class="max-w-2xl bg-default-100 rounded-2xl rounded-tl-sm px-4 py-3 text-sm">
                            @msg.Content
                        </div>
                    </div>

                    @if (msg.Sources is { Count: > 0 })
                    {
                        <div class="ml-2">
                            <details class="text-xs text-default-400">
                                <summary class="cursor-pointer hover:text-default-600 select-none">
                                    @msg.Sources.Count source(s) used
                                </summary>
                                <div class="mt-2 space-y-1 pl-2 border-l-2 border-default-200">
                                    @foreach (var src in msg.Sources)
                                    {
                                        <div class="text-xs">
                                            <span class="font-medium text-default-600">@(src.Title ?? "Untitled")</span>
                                            <span class="text-default-400 ml-1">(score: @src.Score.ToString("F2"))</span>
                                            @if (!string.IsNullOrWhiteSpace(src.Summary))
                                            {
                                                <p class="text-default-400 mt-0.5 line-clamp-2">@src.Summary</p>
                                            }
                                        </div>
                                    }
                                </div>
                            </details>
                        </div>
                    }
                </div>
            }
        }

        @if (_isThinking)
        {
            <div class="flex justify-start">
                <div class="bg-default-100 rounded-2xl rounded-tl-sm px-4 py-3">
                    @if (_streamingContent.Length == 0)
                    {
                        <LumexSpinner Color="@ThemeColor.Primary" Size="@Size.Small" />
                    }
                    else
                    {
                        <div class="max-w-2xl text-sm whitespace-pre-wrap">@_streamingContent.ToString()</div>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <LumexAlert Color="@ThemeColor.Danger" Title="Error">
                @_errorMessage
            </LumexAlert>
        }
    </div>

    @* Input area *@
    <LumexCard Class="p-3">
        <div class="flex gap-2 items-end">
            <textarea @ref="_textareaRef"
                      @bind="_inputText"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      rows="1"
                      placeholder="Ask a question..."
                      disabled="@_isThinking"
                      class="flex-1 resize-none rounded-lg border border-default-200 bg-default-50 px-3 py-2 text-sm focus:outline-none focus:border-primary disabled:opacity-50"
                      style="min-height: 40px; max-height: 120px;"></textarea>
            <LumexButton Color="@ThemeColor.Primary"
                         IsDisabled="@(string.IsNullOrWhiteSpace(_inputText) || _isThinking)"
                         OnClick="SendMessage">
                Send
            </LumexButton>
        </div>
    </LumexCard>
</div>

@code {
    private readonly List<ChatMessage> _messages = [];
    private readonly System.Text.StringBuilder _streamingContent = new();
    private string _inputText = string.Empty;
    private bool _isThinking;
    private string _errorMessage = string.Empty;
    private ElementReference _textareaRef;
    private IJSObjectReference? _jsModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/chat.js");
            await _jsModule.InvokeVoidAsync("preventEnterNewline", _textareaRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            await _jsModule.DisposeAsync();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !string.IsNullOrWhiteSpace(_inputText) && !_isThinking)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrEmpty(text) || _isThinking) return;

        _inputText = string.Empty;
        _errorMessage = string.Empty;
        _streamingContent.Clear();
        _messages.Add(new ChatMessage("user", text, null));
        _isThinking = true;
        StateHasChanged();

        try
        {
            var client = HttpClients.CreateClient("apiservice");
            var request = new HttpRequestMessage(HttpMethod.Post, "/chat/stream")
            {
                Content = JsonContent.Create(new { message = text }),
            };
            request.Headers.Accept.Add(new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("text/event-stream"));

            using var response = await client.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                _errorMessage = $"Request failed ({(int)response.StatusCode}): {error}";
                return;
            }

            List<ChatSource>? sources = null;

            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            string? currentEvent = null;

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (line is null) break;

                if (line.StartsWith("event: "))
                {
                    currentEvent = line["event: ".Length..];
                    continue;
                }

                if (line.StartsWith("data: "))
                {
                    var data = line["data: ".Length..];

                    switch (currentEvent)
                    {
                        case "token":
                            // Data is a JSON-encoded string — deserialise to get the raw text.
                            var token = JsonSerializer.Deserialize<string>(data);
                            if (token is not null)
                            {
                                _streamingContent.Append(token);
                                StateHasChanged();
                            }
                            break;

                        case "sources":
                            sources = JsonSerializer.Deserialize<List<ChatSource>>(data, _jsonOptions);
                            break;

                        case "done":
                            // Stream complete — handled after the loop.
                            break;
                    }

                    currentEvent = null;
                    continue;
                }

                // Blank lines are SSE frame separators — nothing to do.
            }

            _messages.Add(new ChatMessage("assistant", _streamingContent.ToString(), sources));
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _streamingContent.Clear();
            _isThinking = false;
            StateHasChanged();
        }
    }

    private static readonly JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
    };

    private record ChatMessage(string Role, string Content, List<ChatSource>? Sources);
    private record ChatSource(string ConversationId, string? Title, string? Summary, float Score);
}
